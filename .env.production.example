# ============================================================
# material-app 本番環境変数
# このファイルを .env.production にコピーして値を設定
# ============================================================

NODE_ENV=production
PORT=3000

# DBファイルパス
DB_PATH=./data/material.db

# ストレージ
STORAGE_BASE_PATH=./storage

# CORS（本番ドメイン）
CORS_ORIGINS=https://material.irodori-system.com

# 化研マテリアル連携
KAKEN_LOGIN_ID=
KAKEN_LOGIN_PASSWORD=
KAKEN_BASE_URL=https://invoice.kaken-material.co.jp/KakenMyPaperWeb/servlet/com.kakenmypaperweb.wwpbaseobjects.home

# Google API
GOOGLE_VISION_API_KEY=
GEMINI_API_KEY=

# アップロード上限（バイト）
UPLOAD_MAX_SIZE_BYTES=10485760
