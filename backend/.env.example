# ============================================================
# material-cost-management backend 環境変数テンプレート
# このファイルをコピーして .env を作成してください
# .env は git 管理外（.gitignore に記載済み）
# ============================================================

# サーバー設定
PORT=3000
NODE_ENV=development

# DBファイルパス（SQLite）
# 将来 PostgreSQL に移行する場合は db/client.ts を差し替え
DB_PATH=./data/material.db

# ストレージベースパス（CSV保存先）
STORAGE_BASE_PATH=./storage

# ============================================================
# 化研マテリアル 連携設定（Phase 5: MVP完了後に設定）
# 実値をここに書かないこと / ログに出力しないこと
# ============================================================
KAKEN_LOGIN_ID=
KAKEN_LOGIN_PASSWORD=
KAKEN_BASE_URL=https://invoice.kaken-material.co.jp/KakenMyPaperWeb/servlet/com.kakenmypaperweb.wwpbaseobjects.home

# ============================================================
# CORS設定
# フロントエンドのオリジンを指定（カンマ区切りで複数可）
# ============================================================
CORS_ORIGINS=http://localhost:5173

# ============================================================
# ファイルアップロード設定
# ============================================================
# アップロード上限サイズ（バイト）: デフォルト 10MB
UPLOAD_MAX_SIZE_BYTES=10485760
